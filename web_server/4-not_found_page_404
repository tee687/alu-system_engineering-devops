#!/usr/bin/env bash
# Configures Nginx to have a custom 404 error page containing "Ceci n'est pas une page"

# Update package registry and install Nginx
apt-get update -y
apt-get install -y nginx

# Create the custom 404 HTML page with the required string
echo "Ceci n'est pas une page" > /usr/share/nginx/html/custom_404.html

# Configure Nginx to use the custom 404 page
# We locate 'server_name _;' and insert the error_page rule directly below it
error_config="\terror_page 404 /custom_404.html;\n\tlocation = /custom_404.html {\n\t\troot /usr/share/nginx/html;\n\t\tinternal;\n\t}"
sed -i "s|server_name _;|$error_config\n\tserver_name _;|" /etc/nginx/sites-available/default

# Restart Nginx to apply changes
service nginx restart
